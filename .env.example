# PostgreSQL
DATABASE_URL=postgres://tcr:password@db:5432/tiktok_creator_role

# Session HMAC secret (must match the Auth Gateway's SESSION_SECRET)
SESSION_SECRET=

# TikTok Login Kit credentials (https://developers.tiktok.com/apps)
# Required scopes: user.info.basic, user.info.profile, user.info.stats
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Public HTTPS URL where this plugin is reachable (includes path prefix)
BASE_URL=https://plugin-rolelogic.faizo.net/tiktok-creator-role

# Server bind address (default: 0.0.0.0:8088)
LISTEN_ADDR=0.0.0.0:8088

# Auth Gateway integration (required — sync workers call /auth/internal/*)
# Defaults to deriving the origin from BASE_URL if unset. Set explicitly in local dev.
# AUTH_GATEWAY_URL=http://localhost:8090
# Shared secret — must match the Auth Gateway's INTERNAL_API_KEY value
INTERNAL_API_KEY=

# Daily TikTok API quota budget for adaptive refresh interval calculation
TIKTOK_QUOTA_PER_DAY=200000

# Log level (default: tiktok_creator_role=info,tower_http=info)
RUST_LOG=tiktok_creator_role=info,tower_http=info
